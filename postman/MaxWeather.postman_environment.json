{
  "name": "Max Weather (fill from terraform outputs)",
  "values": [
    { "key": "base_url", "value": "https://<api-id>.execute-api.ap-southeast-1.amazonaws.com", "enabled": true },
    { "key": "token_url", "value": "https://maxweather-prod.auth.ap-southeast-1.amazoncognito.com/oauth2/token", "enabled": true },
    { "key": "client_id", "value": "<terraform output -raw cognito_client_id>", "enabled": true },
    { "key": "client_secret", "value": "<terraform output -raw cognito_client_secret>", "type": "secret", "enabled": true },
    { "key": "scope", "value": "maxweather-prod-api/forecast.read", "enabled": true },
    { "key": "access_token", "value": "", "enabled": true }
  ],
  "_postman_variable_scope": "environment"
}
